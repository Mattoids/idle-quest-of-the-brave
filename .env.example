# 勇者挂机传说 — Docker 部署环境变量配置
#
# 使用方法：
#   1) cp .env.example .env
#   2) 修改 .env 里的值
#   3) docker compose up -d
#
# 说明：以下变量会被 docker-compose.yml 引用，也会注入到 web 容器。
#       如果不创建 .env，docker-compose.yml 会使用默认值。

# ======================== 应用基础 ========================

APP_ENV=production
APP_DEBUG=false

# 设备 ID 哈希盐（生产环境务必修改！）
AUTH_DEVICE_SALT=change-this-in-production

# ======================== Redis 缓存 ========================

REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379

# ======================== MySQL 持久化 ========================

MYSQL_ENABLED=true
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=iqotb
MYSQL_USERNAME=iqotb
MYSQL_PASSWORD=iqotb_pwd_change_me

# MySQL root 密码（仅 Docker 部署需要）
MYSQL_ROOT_PASSWORD=root_pwd_change_me
