# 勇者挂机传说 — 服务端环境变量配置
#
# 使用方法：
#   1) cp server/.env.example server/.env
#   2) 修改 server/.env 里的值
#   3) 重启服务（PHP 内置服务器 / Docker）
#
# 优先级：系统环境变量 > .env 文件
# 说明：所有配置均为可选；不填时走 app.php 里的默认值。

# ======================== 应用基础 ========================

# 运行环境：development | production
APP_ENV=development

# 调试模式：true 时返回详细错误堆栈
APP_DEBUG=true

# 设备 ID 哈希盐（生产环境务必修改！同一盐值保证同一设备生成相同哈希）
AUTH_DEVICE_SALT=change-this-in-production

# ======================== OAuth 授权（药丸 / invites.fun）========================
# 需要在 https://www.invites.fun 创建应用并填写回调地址

OAUTH_ENABLED=false
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_BASE_URL=https://www.invites.fun
OAUTH_REDIRECT_URI=
OAUTH_SCOPE=user.read

# ======================== Redis 缓存 ========================
# Redis 用于存档读缓存；关闭后自动降级到 MySQL → File

REDIS_ENABLED=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_AUTH=your-redis-password
# REDIS_DB=0

# ======================== MySQL 持久化 ========================
# MySQL 用于存档持久备份；关闭后存档完全走文件系统

MYSQL_ENABLED=false
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=iqotb
MYSQL_USERNAME=iqotb
MYSQL_PASSWORD=change-me
